{
  "children": [
    {
      "template": "app-package",
      "path": "api",
      "variables": {
        "apps": "\"$${api_package_name}.$${django_app_name}\"",
        "name_kebab": "$${name_kebab}-api",
        "name_pretty": "$${name_pretty} API",
        "name_snake": "$${api_package_name}"
      }
    },
    {
      "template": "django-app",
      "path": "api/$${api_package_name}/$${django_app_name}",
      "variables": {
        "name_snake": "$${django_app_name}",
        "parent_package_name": "$${api_package_name}",
        "api_prefix": "$${api_prefix}"
      }
    },
    {
      "template": "api-client",
      "path": "api-client",
      "variables": {
        "api_client_package_name": "$${api_client_package_name}",
        "api_client_export_name": "$${api_client_export_name}",
        "name_pretty": "$${name_pretty}",
        "name_snake": "$${name_snake}"
      }
    },
    {
      "template": "react-app",
      "path": "web",
      "condition": "with_frontend",
      "variables": {
        "api_client_package_name": "$${api_client_package_name}",
        "auth_client_package_name": "$${auth_client_package_name}",
        "cdn_base_url": "$${cdn_base_url}",
        "ui_package_name": "$${ui_package_name}",
        "web_package_name": "$${web_package_name}",
        "name_snake": "$${name_snake}",
        "name_pretty": "$${name_pretty}",
        "github_user": "$${github_user}",
        "marketing_description": "$${marketing_description}"
      }
    }
  ],
  "hooks": {
    "post_init": [
      {
        "id": "multi-sync",
        "run": "multi sync"
      },
      {
        "id": "pnpm-install",
        "run": "pnpm install",
        "allow_failure": true
      }
    ]
  },
  "github": {
    "create_repo": true,
    "repo_name": "$${name_kebab}",
    "private": true,
    "condition": "with_github"
  }
}
