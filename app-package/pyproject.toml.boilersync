[project]
name = "$${name_kebab}"
version = "0.1.0"
description = ""
authors = []
dependencies = [
    $${% block dependencies %}
    $${% endblock %}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project.entry-points."api_core.installed_apps"]
$${name_snake} = "$${name_snake}.installed_apps:get_installed_apps"

[project.entry-points."api_core.settings"]
$${name_snake} = "$${name_snake}.settings"
